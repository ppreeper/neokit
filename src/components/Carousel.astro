---
import { twMerge } from "tailwind-merge";

/**
 * Carousel container — DaisyUI `carousel` wrapper.
 *
 * Place `<div class="carousel-item">` children inside the default slot.
 * For full-width slides add `w-full` to each item and `w-full` to the img.
 *
 * Basic usage (snap to start, scroll left/right):
 * ```astro
 * <Carousel>
 *   <div class="carousel-item"><img src="/a.jpg" alt="A" /></div>
 *   <div class="carousel-item"><img src="/b.jpg" alt="B" /></div>
 * </Carousel>
 * ```
 *
 * Full-width with indicator buttons (id-based anchor scrolling):
 * ```astro
 * <Carousel id="slider" classes="w-full">
 *   <div id="s1" class="carousel-item w-full"><img src="/a.jpg" class="w-full" alt="" /></div>
 *   <div id="s2" class="carousel-item w-full"><img src="/b.jpg" class="w-full" alt="" /></div>
 * </Carousel>
 * <div class="flex justify-center gap-2 py-2">
 *   <a href="#s1" class="btn btn-xs">1</a>
 *   <a href="#s2" class="btn btn-xs">2</a>
 * </div>
 * ```
 *
 * Vertical carousel:
 * ```astro
 * <Carousel direction="vertical" classes="h-96">
 *   <div class="carousel-item h-full"><img src="/a.jpg" alt="" /></div>
 * </Carousel>
 * ```
 */

interface Props {
    /**
     * Scroll-snap alignment for items.
     * @default "start"
     */
    snap?: "start" | "center" | "end";
    /**
     * Scroll direction.
     * @default "horizontal"
     */
    direction?: "horizontal" | "vertical";
    /** Extra classes on the root carousel element. */
    classes?: string;
}

const {
    snap = "start",
    direction = "horizontal",
    classes,
} = Astro.props;

const snapClass = {
    start: "",
    center: "carousel-center",
    end: "carousel-end",
}[snap];

const directionClass = direction === "vertical" ? "carousel-vertical" : "";

const rootClass = twMerge("carousel", snapClass, directionClass, classes);
---

<div class={rootClass}>
    <slot />
</div>
