---
import { twMerge } from "tailwind-merge";

/**
 * Loading — DaisyUI `loading` spinner component.
 *
 * Renders a `<span class="loading">` element. No children needed —
 * the animation is purely CSS.
 *
 * Types: `"spinner"` (default) | `"dots"` | `"ring"` | `"ball"` |
 *        `"bars"` | `"infinity"`
 *
 * Sizes: `"xs"` | `"sm"` | `"md"` | `"lg"` | `"xl"`
 *
 * Color: any DaisyUI color token (applied via `text-{color}`)
 * e.g. `color="primary"` → `text-primary`
 *
 * ```astro
 * <Loading />
 * <Loading type="dots" size="lg" color="primary" />
 * <Loading type="ring" size="sm" color="error" />
 * ```
 */

interface Props {
    /** Spinner style. Default: `"spinner"`. */
    type?: "spinner" | "dots" | "ring" | "ball" | "bars" | "infinity";
    /** Size. */
    size?: "xs" | "sm" | "md" | "lg" | "xl";
    /** Color token — applied as `text-{color}`. */
    color?: string;
    /** Extra classes. */
    classes?: string;
}

const { type = "spinner", size, color, classes } = Astro.props;

const rootClass = twMerge(
    "loading",
    { spinner: "loading-spinner", dots: "loading-dots", ring: "loading-ring", ball: "loading-ball", bars: "loading-bars", infinity: "loading-infinity" }[type],
    size && { xs: "loading-xs", sm: "loading-sm", md: "loading-md", lg: "loading-lg", xl: "loading-xl" }[size],
    color && ({ primary: "text-primary", secondary: "text-secondary", accent: "text-accent", info: "text-info", success: "text-success", warning: "text-warning", error: "text-error", neutral: "text-neutral" } as Record<string, string>)[color],
    classes,
);
---

<span class={rootClass}></span>
