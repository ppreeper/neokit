---
import { twMerge } from "tailwind-merge";

/**
 * Range — DaisyUI `range` slider input component.
 *
 * Renders a styled `<input type="range">`.
 *
 * Sizes: `"xs"` | `"sm"` | `"md"` (default) | `"lg"` | `"xl"`
 * Colors: `"primary"` | `"secondary"` | `"accent"` | `"info"` |
 *         `"success"` | `"warning"` | `"error"` | `"neutral"`
 *
 * ```astro
 * <Range value={50} />
 * <Range min={0} max={200} step={25} value={100} color="primary" />
 * ```
 */

interface Props {
    /** Current value. */
    value?: number;
    /** Minimum value. Default: 0. */
    min?: number;
    /** Maximum value. Default: 100. */
    max?: number;
    /** Step increment. */
    step?: number;
    /** Disabled state. */
    disabled?: boolean;
    /** Size token. Default: `"md"`. */
    size?: "xs" | "sm" | "md" | "lg" | "xl";
    /** Color token. */
    color?: "primary" | "secondary" | "accent" | "info" | "success" | "warning" | "error" | "neutral";
    /** id attribute. */
    id?: string;
    /** name attribute. */
    name?: string;
    /** Extra classes. */
    classes?: string;
}

const {
    value,
    min = 0,
    max = 100,
    step,
    disabled,
    size = "md",
    color,
    id,
    name,
    classes,
} = Astro.props;

const rootClass = twMerge(
    "range",
    size !== "md" && `range-${size}`,
    color && `range-${color}`,
    classes,
);
---

<input
    type="range"
    class={rootClass}
    value={value}
    min={min}
    max={max}
    step={step}
    disabled={disabled}
    id={id}
    name={name}
/>
