---
import { twMerge } from "tailwind-merge";

/**
 * Diff — DaisyUI side-by-side comparison slider.
 *
 * Renders a draggable resizer between two content panes.
 * Use named slots `item1` and `item2` for each side.
 *
 * Basic image diff:
 * ```astro
 * <Diff>
 *   <img slot="item1" src="/before.webp" alt="before" />
 *   <img slot="item2" src="/after.webp" alt="after" />
 * </Diff>
 * ```
 *
 * Text diff:
 * ```astro
 * <Diff>
 *   <div slot="item1" class="bg-primary text-primary-content grid place-content-center text-9xl font-black">
 *     NEW
 *   </div>
 *   <div slot="item2" class="bg-base-200 grid place-content-center text-9xl font-black">
 *     OLD
 *   </div>
 * </Diff>
 * ```
 */

interface Props {
    /**
     * Aspect ratio class applied to the container.
     * Any Tailwind `aspect-*` class.
     * @default "aspect-16/9"
     */
    aspect?: string;
    /** Extra classes on the root `diff` element. */
    classes?: string;
}

const { aspect = "aspect-16/9", classes } = Astro.props;

const rootClass = twMerge("diff", aspect, classes);
---

<figure class={rootClass} tabindex="0">
    <div class="diff-item-1" role="img" tabindex="0">
        <slot name="item1" />
    </div>
    <div class="diff-item-2" role="img">
        <slot name="item2" />
    </div>
    <div class="diff-resizer"></div>
</figure>
