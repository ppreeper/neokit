---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title ? `${title} — neokit` : "neokit"}</title>
        <script is:inline>
            const lightTheme = "corporate";
            const darkTheme = "business";
            const saved = localStorage.getItem("theme");
            const theme = saved ?? (window.matchMedia("(prefers-color-scheme: dark)").matches ? darkTheme : lightTheme);
            document.documentElement.setAttribute("data-theme", theme);
            document.addEventListener("astro:after-swap", () => {
                const t = localStorage.getItem("theme") ?? lightTheme;
                document.documentElement.setAttribute("data-theme", t);
            });
        </script>
    </head>
    <body class="bg-base-200 min-h-screen flex flex-col">
        <slot />
    </body>
</html>
