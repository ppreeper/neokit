---
import AppLayout from "../../layouts/AppLayout.astro";
import FileInput from "neokit/components/FileInput.astro";
---

<AppLayout title="File Input">
    <h1 id="top" class="text-5xl">File Input</h1>
    <p class="mt-2 opacity-70">
        A styled file picker. Built on{" "}
        <code>&lt;input type="file"&gt;</code> with DaisyUI's{" "}
        <code>file-input</code> class. Supports single/multiple selection,
        accept filters, sizes, color tokens, and bordered/ghost variants.
    </p>

    <!-- ── Default ─────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Default</h2>
    <p class="mt-1 text-sm opacity-70">Basic file input, accepts any file type.</p>

    <fieldset>
        <legend>file-input default</legend>
        <FileInput classes="w-full max-w-xs" />
    </fieldset>

    <!-- ── Sizes ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sizes</h2>
    <p class="mt-1 text-sm opacity-70">
        Five sizes: <code>xs</code> → <code>xl</code>.
    </p>

    <fieldset>
        <legend>file-input sizes</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            {(["xs", "sm", "md", "lg", "xl"] as const).map((s) => (
                <div class="flex items-center gap-3">
                    <span class="w-6 text-xs opacity-60 shrink-0">{s}</span>
                    <FileInput size={s} classes="flex-1" />
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Colors ──────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Colors</h2>
    <p class="mt-1 text-sm opacity-70">All eight DaisyUI color tokens.</p>

    <fieldset>
        <legend>file-input colors</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            {(["primary","secondary","accent","info","success","warning","error","neutral"] as const).map((c) => (
                <div class="flex items-center gap-3">
                    <span class="w-20 text-xs capitalize opacity-60 shrink-0">{c}</span>
                    <FileInput color={c} classes="flex-1" />
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Bordered ────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Bordered</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="bordered"</code> adds a visible border at rest.
    </p>

    <fieldset>
        <legend>file-input bordered</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            <FileInput variant="bordered" />
            <FileInput variant="bordered" color="primary" />
        </div>
    </fieldset>

    <!-- ── Ghost ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Ghost</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="ghost"</code> — transparent background.
    </p>

    <fieldset>
        <legend>file-input ghost</legend>
        <FileInput variant="ghost" classes="w-full max-w-xs" />
    </fieldset>

    <!-- ── Accept filter ──────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Accept filter</h2>
    <p class="mt-1 text-sm opacity-70">
        Use <code>accept</code> to restrict the file picker to specific types.
    </p>

    <fieldset>
        <legend>file-input accept</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            <div>
                <p class="text-xs opacity-60 mb-1">Images only (<code>image/*</code>)</p>
                <FileInput accept="image/*" color="primary" variant="bordered" />
            </div>
            <div>
                <p class="text-xs opacity-60 mb-1">PDF only (<code>.pdf</code>)</p>
                <FileInput accept=".pdf" color="secondary" variant="bordered" />
            </div>
            <div>
                <p class="text-xs opacity-60 mb-1">CSV / Excel (<code>.csv,.xlsx</code>)</p>
                <FileInput accept=".csv,.xlsx" color="accent" variant="bordered" />
            </div>
        </div>
    </fieldset>

    <!-- ── Multiple selection ─────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Multiple files</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>multiple</code> allows the user to select more than one file.
    </p>

    <fieldset>
        <legend>file-input multiple</legend>
        <FileInput multiple accept="image/*" color="primary" variant="bordered" classes="w-full max-w-xs" />
    </fieldset>

    <!-- ── Disabled ────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Disabled</h2>
    <p class="mt-1 text-sm opacity-70">Non-interactive state.</p>

    <fieldset>
        <legend>file-input disabled</legend>
        <FileInput disabled classes="w-full max-w-xs" />
    </fieldset>

    <!-- ── Upload form ────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Upload form</h2>
    <p class="mt-1 text-sm opacity-70">Real-world file upload form inside a card.</p>

    <fieldset>
        <legend>file-input upload form</legend>
        <div class="card bg-base-100 shadow max-w-sm">
            <div class="card-body gap-4">
                <h2 class="card-title">Upload document</h2>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Profile photo</span></div>
                    <FileInput accept="image/*" color="primary" variant="bordered" />
                    <div class="label"><span class="label-text-alt opacity-60">JPG, PNG or WebP · max 5 MB</span></div>
                </label>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Attachments</span></div>
                    <FileInput multiple accept=".pdf,.docx" variant="bordered" />
                    <div class="label"><span class="label-text-alt opacity-60">PDF or DOCX · up to 10 files</span></div>
                </label>
                <div class="card-actions justify-end">
                    <button class="btn btn-ghost">Cancel</button>
                    <button class="btn btn-primary">Upload</button>
                </div>
            </div>
        </div>
    </fieldset>
</AppLayout>
