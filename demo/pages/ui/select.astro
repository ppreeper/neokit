---
import AppLayout from "../../layouts/AppLayout.astro";
import Select from "@ppreeper/neokit/components/Select.astro";
---

<AppLayout title="Select">
    <h1 id="top" class="text-5xl">Select</h1>
    <p class="mt-2 opacity-70">
        A styled dropdown select. Built on the native{" "}
        <code>&lt;select&gt;</code> element with DaisyUI's <code>select</code>{" "}
        class. Pass <code>&lt;option&gt;</code> children via the default slot.
        Supports sizes, colors, and bordered/ghost variants.
    </p>

    <!-- ── Default ─────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Default</h2>
    <p class="mt-1 text-sm opacity-70">Basic select with a placeholder option.</p>

    <fieldset>
        <legend>select default</legend>
        <Select>
            <option disabled selected>Pick a fruit</option>
            <option>Apple</option>
            <option>Banana</option>
            <option>Cherry</option>
            <option>Mango</option>
        </Select>
    </fieldset>

    <!-- ── Sizes ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sizes</h2>
    <p class="mt-1 text-sm opacity-70">
        Five sizes: <code>xs</code> → <code>xl</code>.
    </p>

    <fieldset>
        <legend>select sizes</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            {(["xs", "sm", "md", "lg", "xl"] as const).map((s) => (
                <div class="flex items-center gap-3">
                    <span class="w-6 text-xs opacity-60 shrink-0">{s}</span>
                    <Select size={s} classes="flex-1">
                        <option disabled selected>size-{s}</option>
                        <option>Option A</option>
                        <option>Option B</option>
                    </Select>
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Colors ──────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Colors</h2>
    <p class="mt-1 text-sm opacity-70">All eight DaisyUI color tokens.</p>

    <fieldset>
        <legend>select colors</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            {(["primary","secondary","accent","info","success","warning","error","neutral"] as const).map((c) => (
                <div class="flex items-center gap-3">
                    <span class="w-20 text-xs capitalize opacity-60 shrink-0">{c}</span>
                    <Select color={c} classes="flex-1">
                        <option disabled selected class="capitalize">{c}</option>
                        <option>Option A</option>
                        <option>Option B</option>
                    </Select>
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Bordered ────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Bordered</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="bordered"</code> — always-visible border.
    </p>

    <fieldset>
        <legend>select bordered</legend>
        <div class="flex flex-col gap-3 max-w-xs">
            <Select variant="bordered">
                <option disabled selected>Bordered select</option>
                <option>Option A</option>
                <option>Option B</option>
            </Select>
            <Select variant="bordered" color="primary">
                <option disabled selected>Bordered primary</option>
                <option>Option A</option>
                <option>Option B</option>
            </Select>
        </div>
    </fieldset>

    <!-- ── Ghost ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Ghost</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="ghost"</code> — transparent background.
    </p>

    <fieldset>
        <legend>select ghost</legend>
        <Select variant="ghost" classes="w-full max-w-xs">
            <option disabled selected>Ghost select</option>
            <option>Option A</option>
            <option>Option B</option>
        </Select>
    </fieldset>

    <!-- ── Disabled ────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Disabled</h2>
    <p class="mt-1 text-sm opacity-70">The entire select is non-interactive.</p>

    <fieldset>
        <legend>select disabled</legend>
        <Select disabled>
            <option>Cannot change this</option>
        </Select>
    </fieldset>

    <!-- ── With label ──────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">With label</h2>
    <p class="mt-1 text-sm opacity-70">
        Use <code>form-control</code> + <code>label</code> for accessible labelling.
    </p>

    <fieldset>
        <legend>select labeled</legend>
        <label class="form-control w-full max-w-xs">
            <div class="label"><span class="label-text">Country</span></div>
            <Select variant="bordered" color="primary">
                <option disabled selected>Select your country</option>
                <option>United States</option>
                <option>United Kingdom</option>
                <option>Canada</option>
                <option>Australia</option>
                <option>Germany</option>
            </Select>
        </label>
    </fieldset>

    <!-- ── In a form ───────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Shipping form</h2>
    <p class="mt-1 text-sm opacity-70">Real-world context: address form with selects.</p>

    <fieldset>
        <legend>select form</legend>
        <div class="card bg-base-100 shadow max-w-sm">
            <div class="card-body gap-4">
                <h2 class="card-title">Shipping address</h2>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Country</span></div>
                    <Select variant="bordered">
                        <option disabled selected>Select country</option>
                        <option>United States</option>
                        <option>Canada</option>
                        <option>United Kingdom</option>
                    </Select>
                </label>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">State / Province</span></div>
                    <Select variant="bordered">
                        <option disabled selected>Select state</option>
                        <option>California</option>
                        <option>New York</option>
                        <option>Texas</option>
                    </Select>
                </label>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Delivery speed</span></div>
                    <Select variant="bordered" color="primary">
                        <option>Standard (5–7 days)</option>
                        <option>Express (2–3 days)</option>
                        <option>Overnight</option>
                    </Select>
                </label>
                <div class="card-actions justify-end">
                    <button class="btn btn-primary">Continue</button>
                </div>
            </div>
        </div>
    </fieldset>
</AppLayout>
