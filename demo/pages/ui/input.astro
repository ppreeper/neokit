---
import AppLayout from "../../layouts/AppLayout.astro";
import Input from "neokit/components/Input.astro";
---

<AppLayout title="Input">
    <h1 id="top" class="text-5xl">Input</h1>
    <p class="mt-2 opacity-70">
        A styled text field. Built on the native <code>&lt;input&gt;</code>{" "}
        element with DaisyUI's <code>input</code> class. Supports all standard
        input types, five sizes, eight color tokens, and bordered/ghost variants.
    </p>

    <!-- ── Default ─────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Default</h2>
    <p class="mt-1 text-sm opacity-70">Basic input with placeholder.</p>

    <fieldset>
        <legend>input default</legend>
        <Input placeholder="Type something…" />
    </fieldset>

    <!-- ── Types ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Types</h2>
    <p class="mt-1 text-sm opacity-70">Common native input types.</p>

    <fieldset>
        <legend>input types</legend>
        <div class="flex flex-col gap-3 max-w-sm">
            <Input type="text" placeholder="text" />
            <Input type="email" placeholder="email@example.com" />
            <Input type="password" placeholder="password" />
            <Input type="number" placeholder="42" />
            <Input type="search" placeholder="Search…" />
            <Input type="url" placeholder="https://example.com" />
            <Input type="tel" placeholder="+1 555 000 0000" />
        </div>
    </fieldset>

    <!-- ── Sizes ───────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sizes</h2>
    <p class="mt-1 text-sm opacity-70">
        Five sizes: <code>xs</code>, <code>sm</code>, <code>md</code> (default),{" "}
        <code>lg</code>, <code>xl</code>.
    </p>

    <fieldset>
        <legend>input sizes</legend>
        <div class="flex flex-col gap-3 max-w-sm">
            {(["xs", "sm", "md", "lg", "xl"] as const).map((s) => (
                <div class="flex items-center gap-3">
                    <span class="w-6 text-xs opacity-60 shrink-0">{s}</span>
                    <Input size={s} placeholder={`size-${s}`} classes="flex-1" />
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Colors ──────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Colors</h2>
    <p class="mt-1 text-sm opacity-70">
        Eight DaisyUI color tokens — set the focus ring color.
    </p>

    <fieldset>
        <legend>input colors</legend>
        <div class="flex flex-col gap-3 max-w-sm">
            {(["primary","secondary","accent","info","success","warning","error","neutral"] as const).map((c) => (
                <div class="flex items-center gap-3">
                    <span class="w-20 text-xs capitalize opacity-60 shrink-0">{c}</span>
                    <Input color={c} placeholder={c} classes="flex-1" />
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── Bordered variant ────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Bordered</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="bordered"</code> adds a visible border at rest.
    </p>

    <fieldset>
        <legend>input bordered</legend>
        <div class="flex flex-col gap-3 max-w-sm">
            <Input variant="bordered" placeholder="Bordered input" />
            <Input variant="bordered" color="primary" placeholder="Bordered primary" />
            <Input variant="bordered" color="error" placeholder="Bordered error" />
        </div>
    </fieldset>

    <!-- ── Ghost variant ───────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Ghost</h2>
    <p class="mt-1 text-sm opacity-70">
        <code>variant="ghost"</code> — transparent background, shows on focus.
    </p>

    <fieldset>
        <legend>input ghost</legend>
        <Input variant="ghost" placeholder="Ghost input — click me" classes="w-full max-w-sm" />
    </fieldset>

    <!-- ── States ──────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">States</h2>
    <p class="mt-1 text-sm opacity-70">Disabled and read-only.</p>

    <fieldset>
        <legend>input states</legend>
        <div class="flex flex-col gap-3 max-w-sm">
            <Input disabled placeholder="Disabled input" />
            <Input readonly value="Read-only value" />
        </div>
    </fieldset>

    <!-- ── With label ──────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">With label</h2>
    <p class="mt-1 text-sm opacity-70">
        Wrap in a <code>label</code> or use <code>fieldset</code> +{" "}
        <code>legend</code> for accessible labelling.
    </p>

    <fieldset>
        <legend>input with label</legend>
        <div class="flex flex-col gap-4 max-w-sm">
            <label class="form-control w-full">
                <div class="label"><span class="label-text">Email address</span></div>
                <Input type="email" placeholder="you@example.com" variant="bordered" color="primary" />
                <div class="label"><span class="label-text-alt opacity-60">We'll never share your email.</span></div>
            </label>
            <label class="form-control w-full">
                <div class="label"><span class="label-text">Password</span></div>
                <Input type="password" placeholder="••••••••" variant="bordered" color="primary" />
            </label>
        </div>
    </fieldset>

    <!-- ── In a card form ──────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Form example</h2>
    <p class="mt-1 text-sm opacity-70">A complete sign-in form layout.</p>

    <fieldset>
        <legend>input form</legend>
        <div class="card bg-base-100 shadow max-w-sm">
            <div class="card-body gap-4">
                <h2 class="card-title">Sign in</h2>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Email</span></div>
                    <Input type="email" placeholder="you@example.com" variant="bordered" />
                </label>
                <label class="form-control w-full">
                    <div class="label"><span class="label-text">Password</span></div>
                    <Input type="password" placeholder="••••••••" variant="bordered" />
                </label>
                <div class="card-actions justify-end mt-2">
                    <button class="btn btn-primary w-full">Sign in</button>
                </div>
            </div>
        </div>
    </fieldset>
</AppLayout>
