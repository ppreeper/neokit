---
import AppLayout from "../../layouts/AppLayout.astro";
import Dock from "@ppreeper/neokit/components/Dock.astro";
---

<AppLayout title="Dock">
    <h1 id="top" class="text-5xl">Dock</h1>
    <p class="mt-2 opacity-70">
        A bottom app bar / mobile navigation bar. Built with DaisyUI's{" "}
        <code>dock</code> class. Each child <code>&lt;button&gt;</code> or{" "}
        <code>&lt;a&gt;</code> becomes a dock item. Mark the active item with
        the <code>active</code> attribute or <code>class="dock-active"</code>.
        Add a <code>&lt;span class="dock-label"&gt;</code> for visible labels.
    </p>

    <!-- ── Basic (icons only) ─────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Basic (icons only)</h2>
    <p class="mt-1 text-sm opacity-70">
        Three items, middle one active.
    </p>

    <fieldset>
        <legend>dock basic</legend>
        <div class="relative h-24 rounded-box border border-base-300 overflow-hidden bg-base-200">
            <Dock>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                </button>
                <button class="active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                </button>
            </Dock>
        </div>
    </fieldset>

    <!-- ── With labels ───────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">With labels</h2>
    <p class="mt-1 text-sm opacity-70">
        Add <code>&lt;span class="dock-label"&gt;</code> inside each item to
        show text beneath the icon.
    </p>

    <fieldset>
        <legend>dock labels</legend>
        <div class="relative h-28 rounded-box border border-base-300 overflow-hidden bg-base-200">
            <Dock>
                <button class="active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                    <span class="dock-label">Home</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    <span class="dock-label">Search</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                    <span class="dock-label">Alerts</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    <span class="dock-label">Profile</span>
                </button>
            </Dock>
        </div>
    </fieldset>

    <!-- ── Sizes ─────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sizes</h2>
    <p class="mt-1 text-sm opacity-70">Five sizes — xs through xl.</p>

    <fieldset>
        <legend>dock sizes</legend>
        <div class="flex flex-col gap-4">
            {(["xs", "sm", "md", "lg", "xl"] as const).map((s) => (
                <div>
                    <p class="text-xs opacity-50 mb-1">{s}</p>
                    <div class="relative rounded-box border border-base-300 overflow-hidden bg-base-200" style={`height: ${s === "xs" ? "3.5rem" : s === "sm" ? "4rem" : s === "md" ? "5rem" : s === "lg" ? "6rem" : "7rem"}`}>
                        <Dock size={s}>
                            <button class="active">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                            </button>
                            <button>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                            </button>
                            <button>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                            </button>
                        </Dock>
                    </div>
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── As links ──────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">As links</h2>
    <p class="mt-1 text-sm opacity-70">
        Use <code>&lt;a&gt;</code> tags instead of <code>&lt;button&gt;</code>{" "}
        for anchor-based navigation.
    </p>

    <fieldset>
        <legend>dock links</legend>
        <div class="relative h-28 rounded-box border border-base-300 overflow-hidden bg-base-200">
            <Dock>
                <a href="#" class="active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                    <span class="dock-label">Home</span>
                </a>
                <a href="#">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                    <span class="dock-label">Stats</span>
                </a>
                <a href="#">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    <span class="dock-label">Profile</span>
                </a>
            </Dock>
        </div>
    </fieldset>

    <!-- ── Mobile phone mockup ────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Mobile context</h2>
    <p class="mt-1 text-sm opacity-70">
        The dock is designed to sit at the very bottom of a mobile viewport.
        Here it's shown inside a constrained card simulating a phone screen.
    </p>

    <fieldset>
        <legend>dock mobile</legend>
        <div class="relative w-64 h-96 rounded-3xl border-4 border-base-content/20 overflow-hidden bg-base-100 mx-auto shadow-xl">
            <!-- fake status bar -->
            <div class="h-8 bg-base-300 flex items-center justify-center text-xs opacity-40">9:41</div>
            <!-- page content -->
            <div class="flex-1 p-4">
                <p class="text-sm opacity-50">App content goes here</p>
            </div>
            <!-- dock pinned to bottom -->
            <Dock classes="absolute bottom-0 left-0 right-0">
                <button class="active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                    <span class="dock-label">Home</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    <span class="dock-label">Search</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
                    <span class="dock-label">Alerts</span>
                </button>
                <button>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                    <span class="dock-label">Profile</span>
                </button>
            </Dock>
        </div>
    </fieldset>
</AppLayout>
