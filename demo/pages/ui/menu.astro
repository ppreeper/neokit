---
import AppLayout from "../../layouts/AppLayout.astro";
import Menu from "neokit/components/Menu.astro";
---

<AppLayout title="Menu">
    <h1 id="top" class="text-5xl">Menu</h1>
    <p class="mt-2 opacity-70">
        A vertical (or horizontal) list of navigation items. Built with
        DaisyUI's <code>menu</code> class on a <code>&lt;ul&gt;</code>.
        Items are plain <code>&lt;li&gt;&lt;a&gt;</code> pairs; add{" "}
        <code>active</code>, <code>disabled</code>, or{" "}
        <code>menu-title</code> for states and section headers.
    </p>

    <!-- ── Basic ────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Basic</h2>
    <p class="mt-1 text-sm opacity-70">
        Simple vertical list with a background and rounded box.
    </p>

    <fieldset>
        <legend>menu basic</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li><a>Home</a></li>
            <li><a>About</a></li>
            <li><a>Contact</a></li>
        </Menu>
    </fieldset>

    <!-- ── Active and disabled ───────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Active and disabled</h2>
    <p class="mt-1 text-sm opacity-70">
        Use <code>class="active"</code> on the <code>&lt;a&gt;</code> for the
        current page, and <code>class="disabled"</code> to prevent
        interaction.
    </p>

    <fieldset>
        <legend>menu active disabled</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li><a>Dashboard</a></li>
            <li><a class="active">Analytics</a></li>
            <li><a>Reports</a></li>
            <li><a class="disabled">Billing</a></li>
            <li><a>Settings</a></li>
        </Menu>
    </fieldset>

    <!-- ── Section titles ────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Section titles</h2>
    <p class="mt-1 text-sm opacity-70">
        Add <code>class="menu-title"</code> to an <code>&lt;li&gt;</code> to
        render a non-interactive section heading.
    </p>

    <fieldset>
        <legend>menu titles</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li class="menu-title">Main</li>
            <li><a>Home</a></li>
            <li><a>Dashboard</a></li>
            <li class="menu-title">Account</li>
            <li><a>Profile</a></li>
            <li><a>Settings</a></li>
            <li><a class="disabled">Billing</a></li>
        </Menu>
    </fieldset>

    <!-- ── Submenu ───────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Nested submenu</h2>
    <p class="mt-1 text-sm opacity-70">
        Nest a <code>&lt;ul&gt;</code> directly inside an{" "}
        <code>&lt;li&gt;</code> to create a static submenu.
    </p>

    <fieldset>
        <legend>menu submenu</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li><a>Home</a></li>
            <li>
                <a>Products</a>
                <ul>
                    <li><a>All products</a></li>
                    <li><a>New arrivals</a></li>
                    <li><a>Sale</a></li>
                </ul>
            </li>
            <li><a>Contact</a></li>
        </Menu>
    </fieldset>

    <!-- ── Collapsible submenu ───────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Collapsible submenu</h2>
    <p class="mt-1 text-sm opacity-70">
        Wrap in <code>&lt;details&gt;</code> + <code>&lt;summary&gt;</code>{" "}
        for a toggle-able submenu with no JavaScript required.
    </p>

    <fieldset>
        <legend>menu collapsible</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li><a>Home</a></li>
            <li>
                <details open>
                    <summary>Products</summary>
                    <ul>
                        <li><a>All products</a></li>
                        <li><a>New arrivals</a></li>
                        <li><a>Sale</a></li>
                    </ul>
                </details>
            </li>
            <li>
                <details>
                    <summary>Account</summary>
                    <ul>
                        <li><a>Profile</a></li>
                        <li><a>Settings</a></li>
                    </ul>
                </details>
            </li>
            <li><a>Contact</a></li>
        </Menu>
    </fieldset>

    <!-- ── Horizontal ────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Horizontal</h2>
    <p class="mt-1 text-sm opacity-70">
        Pass <code>horizontal</code> to lay items out in a row — useful for
        top navigation bars.
    </p>

    <fieldset>
        <legend>menu horizontal</legend>
        <Menu horizontal classes="bg-base-200 rounded-box">
            <li><a>Home</a></li>
            <li><a class="active">About</a></li>
            <li><a>Blog</a></li>
            <li><a>Contact</a></li>
        </Menu>
    </fieldset>

    <!-- ── Sizes ─────────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sizes</h2>
    <p class="mt-1 text-sm opacity-70">Five sizes — xs through xl.</p>

    <fieldset>
        <legend>menu sizes</legend>
        <div class="flex flex-wrap gap-6 items-start">
            {(["xs", "sm", "md", "lg", "xl"] as const).map((s) => (
                <div>
                    <p class="text-xs opacity-50 mb-1">{s}</p>
                    <Menu size={s} classes="bg-base-200 rounded-box">
                        <li><a>Item one</a></li>
                        <li><a class="active">Item two</a></li>
                        <li><a>Item three</a></li>
                    </Menu>
                </div>
            ))}
        </div>
    </fieldset>

    <!-- ── With icons ────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">With icons</h2>
    <p class="mt-1 text-sm opacity-70">
        Place an SVG icon before the label text inside the{" "}
        <code>&lt;a&gt;</code>.
    </p>

    <fieldset>
        <legend>menu icons</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li>
                <a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                    Home
                </a>
            </li>
            <li>
                <a class="active">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Details
                </a>
            </li>
            <li>
                <a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                    Stats
                </a>
            </li>
            <li>
                <a>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    Settings
                </a>
            </li>
        </Menu>
    </fieldset>

    <!-- ── Badge in menu item ─────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">With badges</h2>
    <p class="mt-1 text-sm opacity-70">
        Add a <code>badge</code> element at the end of an{" "}
        <code>&lt;a&gt;</code> to show counts or labels inline.
    </p>

    <fieldset>
        <legend>menu badges</legend>
        <Menu classes="bg-base-200 rounded-box w-56">
            <li><a>Inbox <span class="badge badge-sm ml-auto">12</span></a></li>
            <li><a class="active">Starred <span class="badge badge-sm badge-primary ml-auto">3</span></a></li>
            <li><a>Sent</a></li>
            <li><a>Drafts <span class="badge badge-sm badge-warning ml-auto">1</span></a></li>
            <li><a class="disabled">Archive</a></li>
        </Menu>
    </fieldset>

    <!-- ── Sidebar navigation ─────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Sidebar navigation</h2>
    <p class="mt-1 text-sm opacity-70">
        Real-world pattern: a styled sidebar with grouped sections, icons,
        and a badge.
    </p>

    <fieldset>
        <legend>menu sidebar</legend>
        <div class="bg-base-200 rounded-box w-64 p-2">
            <div class="px-4 py-3 font-bold text-lg">My App</div>
            <Menu classes="w-full">
                <li class="menu-title">Workspace</li>
                <li>
                    <a>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
                        Dashboard
                    </a>
                </li>
                <li>
                    <a class="active">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                        Projects
                        <span class="badge badge-xs badge-primary ml-auto">5</span>
                    </a>
                </li>
                <li>
                    <details>
                        <summary>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                            Team
                        </summary>
                        <ul>
                            <li><a>Members</a></li>
                            <li><a>Roles</a></li>
                            <li><a>Invitations</a></li>
                        </ul>
                    </details>
                </li>
                <li class="menu-title">Settings</li>
                <li><a>Profile</a></li>
                <li><a class="disabled">Billing</a></li>
            </Menu>
        </div>
    </fieldset>
</AppLayout>
