---
const pathname = Astro.url.pathname.replace(/\/$/, "");

const groups: { label: string; items: { href: string; label: string }[] }[] = [
    {
        label: "Actions",
        items: [
            { href: "/ui/button", label: "Button" },
            { href: "/ui/dropdown", label: "Dropdown" },
            { href: "/ui/modal", label: "Modal" },
            { href: "/ui/swap", label: "Swap" },
            { href: "/ui/theme-controller", label: "Theme Controller" },
        ],
    },
    {
        label: "Data Display",
        items: [
            { href: "/ui/accordion", label: "Accordion" },
            { href: "/ui/avatar", label: "Avatar" },
            { href: "/ui/badge", label: "Badge" },
            { href: "/ui/card", label: "Card" },
            { href: "/ui/carousel", label: "Carousel" },
            { href: "/ui/chat-bubble", label: "Chat Bubble" },
            { href: "/ui/collapse", label: "Collapse" },
            { href: "/ui/countdown", label: "Countdown" },
            { href: "/ui/diff", label: "Diff" },
            { href: "/ui/kbd", label: "KBD" },
            { href: "/ui/list", label: "List" },
            { href: "/ui/stat", label: "Stat" },
            { href: "/ui/status", label: "Status" },
            { href: "/ui/table", label: "Table" },
            { href: "/ui/timeline", label: "Timeline" },
        ],
    },
    {
        label: "Navigation",
        items: [
            { href: "/ui/breadcrumb", label: "Breadcrumbs" },
            { href: "/ui/dock", label: "Dock" },
            { href: "/ui/menu", label: "Menu" },
            { href: "/ui/navbar", label: "Navbar" },
            { href: "/ui/pagination", label: "Pagination" },
            { href: "/ui/steps", label: "Steps" },
            { href: "/ui/tabs", label: "Tabs" },
        ],
    },
    {
        label: "Feedback",
        items: [
            { href: "/ui/alert", label: "Alert" },
            { href: "/ui/loading", label: "Loading" },
            { href: "/ui/progress", label: "Progress" },
            { href: "/ui/skeleton", label: "Skeleton" },
            { href: "/ui/toast", label: "Toast" },
            { href: "/ui/tooltip", label: "Tooltip" },
        ],
    },
    {
        label: "Data Input",
        items: [
            { href: "/ui/checkbox", label: "Checkbox" },
            { href: "/ui/fileinput", label: "File Input" },
            { href: "/ui/input", label: "Input" },
            { href: "/ui/radio", label: "Radio" },
            { href: "/ui/range", label: "Range" },
            { href: "/ui/rating", label: "Rating" },
            { href: "/ui/select", label: "Select" },
            { href: "/ui/textarea", label: "Textarea" },
            { href: "/ui/toggle", label: "Toggle" },
        ],
    },
    {
        label: "Layout",
        items: [
            { href: "/ui/artboard", label: "Artboard" },
            { href: "/ui/divider", label: "Divider" },
            { href: "/ui/drawer", label: "Drawer" },
            { href: "/ui/footer", label: "Footer" },
            { href: "/ui/hero", label: "Hero" },
            { href: "/ui/indicator", label: "Indicator" },
            { href: "/ui/join", label: "Join" },
            { href: "/ui/mask", label: "Mask" },
            { href: "/ui/stack", label: "Stack" },
        ],
    },
    {
        label: "Mockup",
        items: [
            { href: "/ui/browser", label: "Browser" },
            { href: "/ui/code", label: "Code" },
            { href: "/ui/phone", label: "Phone" },
            { href: "/ui/window", label: "Window" },
        ],
    },
];
---

<nav class="w-56 shrink-0 border-r border-base-300 h-[calc(100vh-3.5rem)] overflow-y-auto bg-base-100">
    <div class="px-3 py-4 space-y-5">
        {groups.map((group) => (
            <div>
                <p class="px-2 mb-1 text-xs font-bold uppercase tracking-wider text-base-content/40 select-none">
                    {group.label}
                </p>
                <ul class="space-y-0.5">
                    {group.items.map((item) => {
                        const active = pathname === item.href || pathname === item.href + "/index";
                        return (
                            <li>
                                <a
                                    href={item.href}
                                    class:list={[
                                        "block px-2 py-1.5 rounded text-sm transition-colors",
                                        active
                                            ? "bg-primary text-primary-content font-medium"
                                            : "text-base-content/80 hover:bg-base-200 hover:text-base-content",
                                    ]}
                                >
                                    {item.label}
                                </a>
                            </li>
                        );
                    })}
                </ul>
            </div>
        ))}
    </div>
</nav>
