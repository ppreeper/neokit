---
import { twMerge } from "tailwind-merge";

/**
 * Select — DaisyUI `select` dropdown component.
 *
 * Renders a styled `<select>` element. Pass `<option>` children via
 * the default slot.
 *
 * Sizes: `"xs"` | `"sm"` | `"md"` (default) | `"lg"` | `"xl"`
 * Colors: `"primary"` | `"secondary"` | `"accent"` | `"info"` |
 *         `"success"` | `"warning"` | `"error"` | `"neutral"`
 * Variants: `"bordered"` | `"ghost"`
 *
 * ```astro
 * <Select>
 *   <option disabled selected>Pick a colour</option>
 *   <option>Red</option>
 *   <option>Blue</option>
 * </Select>
 *
 * <Select color="primary" size="sm">
 *   <option>Option A</option>
 * </Select>
 * ```
 */

interface Props {
    /** Disabled state. */
    disabled?: boolean;
    /** Size token. Default: `"md"`. */
    size?: "xs" | "sm" | "md" | "lg" | "xl";
    /** Color token. */
    color?: "primary" | "secondary" | "accent" | "info" | "success" | "warning" | "error" | "neutral";
    /** Visual variant. */
    variant?: "bordered" | "ghost";
    /** id attribute. */
    id?: string;
    /** name attribute. */
    name?: string;
    /** Extra classes. */
    classes?: string;
}

const {
    disabled,
    size = "md",
    color,
    variant,
    id,
    name,
    classes,
} = Astro.props;

const rootClass = twMerge(
    "select",
    size !== "md" && { xs: "select-xs", sm: "select-sm", lg: "select-lg", xl: "select-xl" }[size],
    color && { primary: "select-primary", secondary: "select-secondary", accent: "select-accent", info: "select-info", success: "select-success", warning: "select-warning", error: "select-error", neutral: "select-neutral" }[color],
    variant && { bordered: "select-bordered", ghost: "select-ghost" }[variant],
    classes,
);
---

<select class={rootClass} disabled={disabled} id={id} name={name}>
    <slot />
</select>
