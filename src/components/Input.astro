---
import { twMerge } from "tailwind-merge";

/**
 * Input — DaisyUI `input` text field component.
 *
 * Renders a styled `<input>` element. The `type` prop controls the
 * native input type (text, email, password, etc.).
 *
 * Sizes: `"xs"` | `"sm"` | `"md"` (default) | `"lg"` | `"xl"`
 * Colors: `"primary"` | `"secondary"` | `"accent"` | `"info"` |
 *         `"success"` | `"warning"` | `"error"` | `"neutral"`
 * Variants: `"bordered"` | `"ghost"`
 *
 * ```astro
 * <Input placeholder="Enter email" type="email" />
 * <Input color="primary" size="lg" placeholder="Search…" />
 * <Input variant="bordered" color="error" value="invalid@" />
 * ```
 */

interface Props {
    /** Native input type. Default: `"text"`. */
    type?: string;
    /** Placeholder text. */
    placeholder?: string;
    /** Current value. */
    value?: string;
    /** Disabled state. */
    disabled?: boolean;
    /** Read-only state. */
    readonly?: boolean;
    /** Size token. Default: `"md"`. */
    size?: "xs" | "sm" | "md" | "lg" | "xl";
    /** Color token. */
    color?: "primary" | "secondary" | "accent" | "info" | "success" | "warning" | "error" | "neutral";
    /** Visual variant. */
    variant?: "bordered" | "ghost";
    /** id attribute (for label association). */
    id?: string;
    /** name attribute. */
    name?: string;
    /** Extra classes. */
    classes?: string;
}

const {
    type = "text",
    placeholder,
    value,
    disabled,
    readonly,
    size = "md",
    color,
    variant,
    id,
    name,
    classes,
} = Astro.props;

const rootClass = twMerge(
    "input",
    size !== "md" && { xs: "input-xs", sm: "input-sm", lg: "input-lg", xl: "input-xl" }[size],
    color && { primary: "input-primary", secondary: "input-secondary", accent: "input-accent", info: "input-info", success: "input-success", warning: "input-warning", error: "input-error", neutral: "input-neutral" }[color],
    variant && { bordered: "input-bordered", ghost: "input-ghost" }[variant],
    classes,
);
---

<input
    type={type}
    class={rootClass}
    placeholder={placeholder}
    value={value}
    disabled={disabled}
    readonly={readonly}
    id={id}
    name={name}
/>
