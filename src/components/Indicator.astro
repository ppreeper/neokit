---
import { twMerge } from "tailwind-merge";

interface Props {
    /**
     * Position of the indicator badge relative to the wrapped content.
     * Defaults to `top-end` (top-right).
     */
    position?:
        | "top-start"
        | "top-center"
        | "top-end"
        | "middle-start"
        | "middle-center"
        | "middle-end"
        | "bottom-start"
        | "bottom-center"
        | "bottom-end";
    classes?: string;
    /** Extra classes for the indicator-item span */
    itemClasses?: string;
}

const { position, classes, itemClasses } = Astro.props;

const posClassMap = {
    "top-start":    "indicator-top indicator-start",
    "top-center":   "indicator-top indicator-center",
    "top-end":      "indicator-top indicator-end",
    "middle-start": "indicator-middle indicator-start",
    "middle-center":"indicator-middle indicator-center",
    "middle-end":   "indicator-middle indicator-end",
    "bottom-start": "indicator-bottom indicator-start",
    "bottom-center":"indicator-bottom indicator-center",
    "bottom-end":   "indicator-bottom indicator-end",
} as const;
const posClass = position ? posClassMap[position] : "";
const itemClass = twMerge("indicator-item", posClass, itemClasses);
const wrapClass = twMerge("indicator", classes);
---

<div class={wrapClass}>
    <!-- Badge/label goes here -->
    <span class={itemClass}><slot name="indicator" /></span>
    <!-- Main content goes here -->
    <slot />
</div>
