---
import AppLayout from "../../layouts/AppLayout.astro";
import ThemeController from "neokit/components/ThemeController.astro";
---

<AppLayout title="Theme Controller">
    <h1 id="top" class="text-5xl">Theme Controller</h1>
    <p class="mt-2 opacity-70">
        A checked <code>theme-controller</code> input switches the entire page theme via CSS — no JS required.
        Use JS + <code>localStorage</code> if you need the choice to persist on page refresh.
    </p>

    <!-- ── Toggle (checkbox) ────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Toggle</h2>
    <p class="mt-1 text-sm opacity-70">A checkbox styled as a toggle. Unchecked = current/default theme. Checked = the named theme.</p>

    <fieldset>
        <legend>Bare toggle — switches to synthwave</legend>
        <ThemeController theme="synthwave" variant="toggle" />
    </fieldset>

    <fieldset>
        <legend>Toggle with text labels</legend>
        <label class="flex cursor-pointer gap-2 items-center">
            <span class="label-text">Default</span>
            <ThemeController theme="synthwave" variant="toggle" />
            <span class="label-text">Synthwave</span>
        </label>
    </fieldset>

    <fieldset>
        <legend>Toggle with sun / moon icons (outside)</legend>
        <label class="flex cursor-pointer gap-2 items-center">
            <!-- sun -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5" />
                <path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
            </svg>
            <ThemeController theme="synthwave" variant="toggle" />
            <!-- moon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
        </label>
    </fieldset>

    <fieldset>
        <legend>Toggle with icons inside (DaisyUI toggle icon variant)</legend>
        <label class="toggle text-base-content">
            <ThemeController theme="synthwave" variant="toggle" classes="hidden" />
            <input type="checkbox" value="synthwave" class="theme-controller" />
            <svg aria-label="sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2" fill="none" stroke="currentColor">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path d="M12 2v2M12 20v2m-7.07-14.07 1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2m-4.34 5.66-1.41 1.41M6.34 6.34 4.93 4.93"></path>
                </g>
            </svg>
            <svg aria-label="moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-4">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2" fill="none" stroke="currentColor">
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
                </g>
            </svg>
        </label>
    </fieldset>

    <fieldset>
        <legend>Custom colors on the toggle</legend>
        <ThemeController
            theme="synthwave"
            variant="toggle"
            classes="border-sky-400 bg-amber-300 [--tglbg:var(--color-sky-500)] checked:border-blue-800 checked:bg-blue-300 checked:[--tglbg:var(--color-blue-900)]"
        />
    </fieldset>

    <!-- ── Checkbox ──────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Checkbox</h2>
    <p class="mt-1 text-sm opacity-70">Same logic as toggle, just a regular checkbox appearance.</p>

    <fieldset>
        <legend>Checkbox — switches to synthwave</legend>
        <label class="flex cursor-pointer gap-2 items-center">
            <ThemeController theme="synthwave" variant="checkbox" />
            <span class="label-text">Synthwave</span>
        </label>
    </fieldset>

    <!-- ── Swap + theme-controller ──────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Swap with theme-controller</h2>
    <p class="mt-1 text-sm opacity-70">
        Compose a <code>swap</code> label with a <code>theme-controller</code> checkbox inside.
        The hidden checkbox drives both the swap animation and the theme switch simultaneously.
    </p>

    <fieldset>
        <legend>Sun / moon rotate — switches to synthwave</legend>
        <label class="swap swap-rotate text-4xl">
            <input type="checkbox" class="theme-controller" value="synthwave" />
            <!-- sun (off = default theme) -->
            <svg class="swap-off size-8 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
            </svg>
            <!-- moon (on = synthwave theme) -->
            <svg class="swap-on size-8 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
            </svg>
        </label>
    </fieldset>

    <!-- ── Radio inputs ──────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Radio inputs</h2>
    <p class="mt-1 text-sm opacity-70">Radio inputs in a group — only one theme active at a time.</p>

    <fieldset>
        <legend>Radio group — 5 themes</legend>
        <div class="fieldset gap-1">
            {[
                { theme: "default", label: "Default" },
                { theme: "retro",   label: "Retro" },
                { theme: "cyberpunk", label: "Cyberpunk" },
                { theme: "valentine", label: "Valentine" },
                { theme: "aqua",    label: "Aqua" },
            ].map(({ theme, label }) => (
                <label class="flex gap-2 cursor-pointer items-center">
                    <ThemeController
                        type="radio"
                        name="theme-radio-demo"
                        theme={theme}
                        variant="radio"
                        classes="radio-sm"
                    />
                    <span class="label-text">{label}</span>
                </label>
            ))}
        </div>
    </fieldset>

    <!-- ── Radio buttons (join) ──────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Radio buttons</h2>
    <p class="mt-1 text-sm opacity-70">Radio inputs styled as buttons, grouped in a join.</p>

    <fieldset>
        <legend>Vertical join</legend>
        <div class="join join-vertical">
            {[
                { theme: "default",   label: "Default" },
                { theme: "retro",     label: "Retro" },
                { theme: "cyberpunk", label: "Cyberpunk" },
                { theme: "valentine", label: "Valentine" },
                { theme: "aqua",      label: "Aqua" },
            ].map(({ theme, label }) => (
                <ThemeController
                    type="radio"
                    name="theme-btn-v"
                    theme={theme}
                    variant="btn"
                    classes="join-item"
                    aria-label={label}
                />
            ))}
        </div>
    </fieldset>

    <fieldset>
        <legend>Horizontal join</legend>
        <div class="join">
            {[
                { theme: "default",  label: "Default" },
                { theme: "dim",      label: "Dim" },
                { theme: "nord",     label: "Nord" },
                { theme: "sunset",   label: "Sunset" },
            ].map(({ theme, label }) => (
                <ThemeController
                    type="radio"
                    name="theme-btn-h"
                    theme={theme}
                    variant="btn"
                    classes="join-item btn-sm"
                    aria-label={label}
                />
            ))}
        </div>
    </fieldset>

    <!-- ── Dropdown ──────────────────────────────────────────────────────── -->
    <h2 class="text-3xl mt-8">Dropdown</h2>
    <p class="mt-1 text-sm opacity-70">Radio buttons inside a dropdown — pick a theme from a menu.</p>

    <fieldset>
        <legend>Theme picker dropdown</legend>
        <div class="dropdown mb-64">
            <div tabindex="0" role="button" class="btn m-1">
                Theme
                <svg width="12" height="12" class="inline-block fill-current opacity-60" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2048 2048">
                    <path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z" />
                </svg>
            </div>
            <ul tabindex="-1" class="dropdown-content bg-base-300 rounded-box z-10 w-52 p-2 shadow-2xl">
                {[
                    { theme: "default",   label: "Default" },
                    { theme: "retro",     label: "Retro" },
                    { theme: "cyberpunk", label: "Cyberpunk" },
                    { theme: "valentine", label: "Valentine" },
                    { theme: "aqua",      label: "Aqua" },
                    { theme: "synthwave", label: "Synthwave" },
                    { theme: "dracula",   label: "Dracula" },
                    { theme: "night",     label: "Night" },
                ].map(({ theme, label }) => (
                    <li>
                        <ThemeController
                            type="radio"
                            name="theme-dropdown-demo"
                            theme={theme}
                            variant="btn"
                            classes="w-full btn-sm btn-block btn-ghost justify-start"
                            aria-label={label}
                        />
                    </li>
                ))}
            </ul>
        </div>
    </fieldset>
</AppLayout>
