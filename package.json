{
  "name": "neokit",
  "version": "1.0.3",
  "description": "An Astro component library extending DaisyUI and Tailwind CSS v4.",
  "author": "Peter Preeper",
  "license": "MIT",
  "keywords": ["astro", "astro-component", "astro-integration", "daisyui", "tailwind", "tailwindcss", "components", "ui"],
  "homepage": "https://github.com/ppreeper/neokit",
  "repository": {
    "type": "git",
    "url": "https://github.com/ppreeper/neokit.git"
  },
  "bugs": {
    "url": "https://github.com/ppreeper/neokit/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./integration": "./src/integration.ts",
    "./components/*": "./src/components/*.astro"
  },
  "files": [
    "src/components",
    "src/index.ts",
    "src/integration.ts"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "@tailwindcss/vite": ">=4.0.0"
  },
  "dependencies": {
    "daisyui": "^5.5.19",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "astro": "^6.0.4"
  }
}
